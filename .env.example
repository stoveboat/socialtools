# DeepSeek
# Get from https://platform.deepseek.com -> API Keys
DEEPSEEK_API_KEY=

# Supabase
# Get from your Supabase project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL used in email confirmation redirects.
# In dev, leave as http://localhost:3000. On Vercel, you can leave this
# unset — the code falls back to VERCEL_PROJECT_PRODUCTION_URL (auto-
# provided by Vercel on every deployment). Set this only for a custom
# domain or to override Vercel's auto-detection.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
